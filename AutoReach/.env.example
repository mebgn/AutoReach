SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SENDER_EMAIL=your_email@gmail.com
USE_TLS=true
# Optional: custom CA cert bundle path if your network intercepts TLS
# SSL_CA_BUNDLE=/absolute/path/to/ca-bundle.pem

# Fallback values if company/subject/name are empty in CSV
DEFAULT_SUBJECT=Internship Application - Your name
DEFAULT_COMPANY=your company 
DEFAULT_NAME=Hiring Team

# Safety / control
SEND_DELAY_SECONDS=3
MAX_EMAILS_PER_RUN=

# Output
LOG_FILE=sent_log.csv
